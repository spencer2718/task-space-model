# Task-Space Model Environment Variables
# Copy to .env: cp .env.example .env

# =============================================================================
# API Keys (both OPTIONAL for most workflows)
# =============================================================================

# O*NET API Key (OPTIONAL)
# Only needed if using O*NET Web Services API directly.
# Most workflows use the downloaded database instead (data/onet/db_30_0_excel/).
# Register at: https://services.onetcenter.org/developer/
# ONET_API_KEY=your_key_here

# IPUMS API Key (OPTIONAL)
# Only needed if regenerating CPS transitions from scratch.
# The processed transitions file is committed to the repo.
# Register at: https://account.ipums.org/api_keys
# IPUMS_API_KEY=your_key_here

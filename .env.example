# Task-Space Model Environment Variables
# Copy this file to .env and fill in your API keys

# O*NET Web Services API Key
# Register at: https://services.onetcenter.org/developer/
# Used for: O*NET API access (optional - can use downloaded database instead)
ONET_API_KEY=your_onet_api_key_here

# IPUMS API Key
# Register at: https://account.ipums.org/api_keys
# Used for: Automated CPS/Census microdata extraction
IPUMS_API_KEY=your_ipums_api_key_here

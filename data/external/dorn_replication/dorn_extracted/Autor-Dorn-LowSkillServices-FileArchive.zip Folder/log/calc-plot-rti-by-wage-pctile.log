. keep occ1990dd psh1-psh100 R33_3a hsd hsg smc clg year

. sort occ1990dd

. 
. * Calculate weighted mean of R33_3a
. forvalues perc=1(1)100 {
  2.         capture drop percwt
  3.         egen percwt=sum(psh`perc')
  4.         * RTI measures that apply to all workers
.         foreach v in R33_3a {
  5.                 egen perc_`v'_`perc' = sum(psh`perc'*`v'/percwt)
  6.         }
  7. }

. keep if _n==1

\begin_layout Subsection*
Computation of results (folder 
\emph on
/do
\emph default
)
\end_layout

\begin_layout Standard
The following Stata do-files produce our main results:
\end_layout

\begin_layout Itemize

\emph on
czone_analysis_final.do
\emph default
 computes the results for Table 3, Table 4, Table 5, Table 6, Table 7 (Panel
 A), Appendix Table 3, Appendix Table 4 (Panel A), and the two Online Appendix
 Tables.
\end_layout

\begin_layout Itemize

\emph on
occ1990dd_stats.do
\emph default
 computes the results for Table 1, Table 2, Appendix Table 1, Appendix Table
 2, Appendix Table 4 (Panel B), and the data input for Figure 3.
\end_layout

\begin_layout Itemize

\emph on
microwage1980_2005_regression.do
\emph default
 computes the results for Table 7 (Panel B).
 This file draws on individual-level microdata from the 1980 Census and
 the 2005 ACS which is not contained in this data distribution due to very
 large file size.
\end_layout

\begin_layout Itemize

\emph on
plot-demp-bypctile-1980-2005-rewt.do
\emph default
 computes the employment polarization graphs for Figure 1 (Panel A), Figure
 2 (Panel A), and Figure 5 (Panel A).
 
\end_layout

\begin_layout Itemize

\emph on
calc-plot-dwage-by-occ-pctile-1980-2005.do
\emph default
 computes the wage polarization graphs for Figure 1 (Panel B), Figure 2
 (Panel B), and Figure 5 (Panel B).
 
\end_layout

\begin_layout Itemize

\emph on
plot-svc-growth-barchart-p20.do
\emph default
 computes the bar chart of Figure 3.
\end_layout

\begin_layout Itemize

\emph on
calc-plot-rti-by-wage-pctile.do 
\emph default
computes the graph of Figure 4.
 
\end_layout

\begin_layout Itemize

\emph on
czone_plot_final.do
\emph default
 computes the scatterplots for Figure 6.
\end_layout

